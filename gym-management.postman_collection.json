{
  "info": {
    "_postman_id": "gym-management-collection",
    "name": "Gym Management System API",
    "description": "Pruebas API - Sistema Gym",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gym.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "SEDES",
      "item": [
        {
          "name": "Crear Sede",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sedes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sedes"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Sede Norte\",\n  \"direccion\": \"Calle 10 # 20-30\"\n}"
            }
          }
        },
        {
          "name": "Listar Sedes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sedes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sedes"
              ]
            }
          }
        },
        {
          "name": "Buscar Sede por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sedes/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sedes",
                "1"
              ]
            }
          }
        },
        {
          "name": "Eliminar Sede",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sedes/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sedes",
                "1"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "MAQUINAS",
      "item": [
        {
          "name": "Crear Maquina",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maquinas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maquinas"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Press Banca\",\n  \"estado\": \"OPERATIVA\",\n  \"sedeId\": 1\n}"
            }
          }
        },
        {
          "name": "Listar Maquinas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maquinas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maquinas"
              ]
            }
          }
        },
        {
          "name": "Maquinas por Sede",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maquinas/sede/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maquinas",
                "sede",
                "1"
              ]
            }
          }
        },
        {
          "name": "Eliminar Maquina",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/maquinas/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maquinas",
                "1"
              ]
            }
          }
        }
      ]
    }
  ]
}